services:

  # ==============================

  # Backend Service

  # ==============================

  backend:

    build: .             # Build the backend image from Dockerfile

    container_name: my-backend   # Name of the backend container

    ports:


      - "3000:3000"              # Host:Container port mapping

    env_file:

      - ./src/.env          # Load environment variables from .env

    depends_on:                  # Ensure these start before backend

      - nlpservice  

      - rabbitmq

    restart: always      # Auto-restart unless manually stopped


  # ==============================
  # Adminer (DB UI)
  # ==============================
  adminer:
    image: adminer
    container_name: adminer
    restart: unless-stopped
    ports:
      - "8080:8080"
    extra_hosts:
      - "host.docker.internal:host-gateway"


  # ==============================

  # RabbitMQ Service

  # ==============================

  rabbitmq:

    image: rabbitmq:3-management # RabbitMQ with management dashboard

    container_name: rabbitmq

    restart: always

    ports:

      - "5672:5672"              # RabbitMQ broker

      - "15672:15672"            # RabbitMQ management UI



  # ==============================

  # AI Service

  # ==============================

  nlpservice:

    build: ./AI

    container_name: nlpservice

    ports:

    - "5000:5000" 





# ==============================

# Named Volumes (persistent storage)

# ==============================

volumes: {}
